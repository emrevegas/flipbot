# Ada control bot — KOPYALA: ada.env  (git'e gitmez)
# Discord Developer Portal'da AYRI bir uygulama/bot oluştur, token'ı buraya yaz.

ADA_BOT_TOKEN=buraya_ada_bot_discord_token

# Senin Discord user ID (slash komut yetkisi)
OWNER_ID=123456789012345678

# License API (ana VDS IP — domain gerekmez)
LICENSE_SERVER_IP=31.210.40.211
LICENSE_SERVER_PORT=8787
LICENSE_ADMIN_KEY=guclu-admin-anahtarin

# /build komutu için (opsiyonel — build yapacaksan doldur)
RELEASES_GITHUB_REPO=kullanici/flipbot-releases
GITHUB_TOKEN=ghp_...

